    {% else if target == "only-not-in-ostim" %}
        {% set ostimCondition = not is_in_faction(participantItem.UUID, "OStimActorCountFaction") %}
    {% else %}
        {% set ostimCondition = true %}
    {% endif %}
    {% if not participant.isChild and ostimCondition and not is_in_faction(participantItem.UUID, "SexLabAnimatingFaction") and not is_in_combat(participantItem.UUID) and not participant.isBusy %}
        ### {{ participant.name }} ({{ participant.gender }} {{ participant.race }})

        {{ render_character_profile("tton_gm", participantItem.UUID) }}
        ---
